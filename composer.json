{
    "require": {
        "php": ">=7.2.28"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
        "test:unit:be": "vendor/bin/phpunit --configuration phpunit.xml.dist",
        "cs:check": "vendor/bin/php-cs-fixer fix --dry-run --verbose",
        "cs:fix": "vendor/bin/php-cs-fixer fix"
    }
}
