{
  "name": "quicktasker",
  "version": "1.0.0",
  "description": "",
  "main": "./src/landing/index.js",
  "scripts": {
    "build": "wp-scripts build && npx tailwindcss -i src/tailwind.css -o build/tailwind.css",
    "start": "concurrently \"wp-scripts start\" \"npx tailwindcss -i src/tailwind.css -o build/tailwind.css --watch\"",
    "lint": "wp-scripts lint-js src",
    "lint:fix": "wp-scripts lint-js src --fix",
    "format": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:e2e": "npm run wp-env:start && playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:headed": "npm run wp-env:start && playwright test --headed",
    "test:e2e:ui": "npm run wp-env:start && playwright test --ui",
    "test:e2e:debug": "npm run wp-env:start && playwright test --debug",
    "test:e2e:codegen": "npm run wp-env:start && playwright codegen http://localhost:8889",
    "test:e2e:codegen:auth": "npm run wp-env:start && playwright codegen http://localhost:8889 --load-storage=playwright/.auth/user.json",
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:reset": "wp-env reset",
    "wp-env:cli": "wp-env run cli",
    "build:emails": "mjml php/templates/email/mjml/*.mjml -o php/templates/email",
    "prepare": "husky"
  },
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.25.1",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.39",
    "@wordpress/env": "11.4.0",
    "@wordpress/scripts": "32.1.0",
    "concurrently": "8.2.2",
    "eslint": "9.39.4",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.6.0",
    "husky": "9.1.6",
    "jest": "29.7.0",
    "jest-environment-jsdom": "30.3.0",
    "mjml": "5.0.0-alpha.11",
    "pdf-parse": "2.4.5",
    "prettier": "3.3.3",
    "prettier-plugin-organize-imports": "4.1.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "3.4.6",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "typescript": "5.5.4",
    "typescript-eslint": "8.59.3",
    "webpack-bundle-analyzer": "4.10.2"
  },
  "dependencies": {
    "@headlessui/react": "2.1.2",
    "@hello-pangea/dnd": "16.6.0",
    "@heroicons/react": "2.1.5",
    "@types/js-cookie": "3.0.6",
    "@uiw/react-color": "2.3.4",
    "@wordpress/api-fetch": "7.4.0",
    "@wordpress/element": "6.4.0",
    "@wordpress/i18n": "5.9.0",
    "clsx": "2.1.1",
    "dayjs": "1.11.13",
    "dayjs-plugin-utc": "0.1.2",
    "js-cookie": "3.0.5",
    "react-datetime-picker": "6.0.1",
    "react-google-charts": "5.2.1",
    "react-icons": "5.3.0",
    "react-loader-spinner": "6.1.6",
    "react-router-dom": "6.30.3",
    "react-switch": "7.0.0",
    "react-toastify": "10.0.5",
    "react-tooltip": "5.28.0",
    "zod": "3.24.1"
  },
  "overrides": {
    "postcss": "8.5.14",
    "serialize-javascript": "7.0.5",
    "minimatch": "3.1.5",
    "webpack-dev-server": "5.2.4",
    "@wordpress/env": {
      "ajv": "8.20.0"
    }
  }
}
